# Copy to .env and fill in. NEVER commit .env — it holds your client secret.

# --- Your vehicle -----------------------------------------------------------
VIN=
DISPLAY_NAME=Tesla

# --- Your Tesla developer app ----------------------------------------------
# https://developer.tesla.com  ->  your app  ->  Credentials & APIs
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=

# Regional Fleet API base URL. North America shown; use the one matching
# your account region (eu / cn variants exist).
TESLA_API_BASE=https://fleet-api.prd.na.vn.cloud.tesla.com

# --- Public hostname --------------------------------------------------------
# Must resolve to your home IP. Used for BOTH:
#   - the car's telemetry endpoint  (${DOMAIN}:${TELEMETRY_PORT}, self-signed)
#   - the partner-domain public key (https://${DOMAIN}/.well-known/..., Let's Encrypt)
DOMAIN=
LE_EMAIL=

# --- Ports ------------------------------------------------------------------
# TELEMETRY_PORT must be forwarded from the internet to this host.
# 80 and 443 must also be forwarded (Let's Encrypt + the public key).
TELEMETRY_PORT=4443

# The shim's Fleet API replacement. Point TeslaMate's TESLA_API_HOST at this.
# SECURITY: keep SHIM_BIND on loopback or a VPN address. The API is
# unauthenticated and includes your location.
SHIM_BIND=127.0.0.1
SHIM_PORT=8099

# Streaming endpoint for TeslaMate's TESLA_WSS_HOST.
WSS_BIND=127.0.0.1
WSS_PORT=8443

# Bind addresses for the Let's Encrypt / public-key server. These must be
# reachable from the internet, so 0.0.0.0 is expected here.
HTTP_BIND=0.0.0.0
HTTPS_BIND=0.0.0.0

# Local-only port for the one-time vehicle-command signing proxy.
PROXY_PORT=4444

# --- Behaviour --------------------------------------------------------------
# If no telemetry signal arrives for this long, the shim reports the car as
# asleep (TeslaMate then backs off). With Sentry Mode on, cars stream
# regularly and rarely hit this.
ASLEEP_AFTER_SEC=1200
